{
  "schemaVersion": 1,
  "id": "recruitmentaddon",
  "version": "${version}",
  "name": "EarthMC Recruitment Addon",
  "description": "Client-side EarthMC recruiting assistant with new-player join alerts and copyable recruit messages.",
  "icon": {
    "64": "assets/recruitmentaddon/icon-64.png",
    "128": "assets/recruitmentaddon/icon-128.png",
    "256": "assets/recruitmentaddon/icon-256.png",
    "512": "assets/recruitmentaddon/icon-512.png"
  },
  "authors": ["JR1258"],
  "contact": {
    "homepage": "https://modrinth.com/mod/earthmc-recruitment",
    "sources": "https://github.com/JR1258/EarthMC-Recruitment-Addon",
    "issues": "https://github.com/JR1258/EarthMC-Recruitment-Addon/issues"
  },
  "license": "Apache-2.0",
  "environment": "client",
  "entrypoints": {
    "client": ["net.recruitmentaddon.RecruitmentAddon"],
    "modmenu": ["net.recruitmentaddon.gui.RecruitmentModMenuIntegration"]
  },
  "mixins": [
    "recruitmentaddon.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.0",
    "fabric-api": "*",
    "minecraft": ">=26.1 <26.2"
  },
  "suggests": {
    "modmenu": "*"
  }
}
